---
import "@scss/global.scss";

import MainLayout from "@/layouts/MainLayout.astro";
import CardClickable from "@/partials/CardClickable.astro";
import Github from "@/icons/Github.astro";
import Youtube from "@/icons/Youtube.astro";
import Behance from "@/icons/Behance.astro";
import Fiverr from "@/icons/Fiverr.astro";
import Home from "@/icons/Home.astro";
---

<MainLayout>
  <main>
    <h1>Esto es incómodo...</h1>
    <p>Parece que no hay nada por aquí :(</p>
    <h2>Pero no te vayas!</h2>
    <p>Aun puedes ver mi trabajo en estos sitios web:</p>
    <nav class="card-container">
      <CardClickable href="https://www.github.com/justfernandomalpica">
        <Github class="hero__icon" />
        <p>GitHub</p>
      </CardClickable>

      <CardClickable href="https://www.youtube.com/@justfernandomalpica">
        <Youtube class="hero__icon" />
        <p>Youtube</p>
      </CardClickable>

      <CardClickable href="https://www.behance.net/justfernandomalpica">
        <Behance class="hero__icon" />
        <p>Behance</p>
      </CardClickable>

      <CardClickable href="https://www.fiverr.com/jfmalpica">
        <Fiverr class="hero__icon" />
        <p>Fiverr</p>
      </CardClickable>
    </nav>
    <p>O si lo prefieres puedes ir al inicio :)</p>
    <CardClickable class="go-home-card" href="/" target="_self">
      <Home />
      Inicio
    </CardClickable>
  </main>
</MainLayout>

<style lang="scss">
  @use "@scss/mixins.scss" as m;
  @use "@scss/variables.scss" as v;

  main {
    @include m.center-content;
    margin-top: v.$outer-separation;
    margin-bottom: v.$outer-separation;

    display: flex;
    flex-direction: column;
    gap: v.$outer-separation;

    h1,
    h2 {
      text-align: center;
    }
    h1 {
      font-size: 3rem;
    }

    h2 {
      font-size: 2rem;
    }

    .card-container {
      @include m.container($gap: v.$inner-separation);
    }

    .go-home-card {
      width: fit-content;
      display: flex;
      flex-direction: row;
      gap: v.$inner-separation;
      margin: 0 auto;
    }
  }
</style>

---
import Linkedin from "@/icons/Linkedin.astro";
import Github from "@/icons/Github.astro";
import Youtube from "@/icons/Youtube.astro";
import Behance from "@/icons/Behance.astro";
import Mail from "@/icons/Mail.astro";

import Card from "@/partials/Card.astro";
import Fiverr from "@/icons/Fiverr.astro";
import CardClickable from "@/partials/CardClickable.astro";
---

<section class="hero">
  <img
    class="hero__avatar"
    src="/img/me.webp"
    alt="Fotorafía tipo avatar de Fernando De Los Santos Malpica"
  />
  <Card class="hero__info">
    <h1>Ing.&nbsp;Fernando De Los Santos Malpica</h1>
    <p>
      Electrónica, programación, música y videojuegos. Amo la tecnología en el
      arte y el arte de la tecnología.
    </p>
  </Card>

  <nav class="hero__contact">
    <Card id="card-email-sender" class="contact-card">
      <Mail class="hero__icon" />
      <p>Contáctame</p>
    </Card>

    <CardClickable
      class="contact-card"
      href="https://www.linkedin.com/in/fernando-de-los-santos-malpica"
    >
      <Linkedin class="hero__icon" />
      <p>Saber mas</p>
    </CardClickable>
  </nav>

  <nav class="hero__links">
    <CardClickable href="https://www.github.com/justfernandomalpica">
      <Github class="hero__icon" />
      <p>GitHub</p>
    </CardClickable>

    <CardClickable href="https://www.youtube.com/@justfernandomalpica">
      <Youtube class="hero__icon" />
      <p>Youtube</p>
    </CardClickable>

    <CardClickable href="https://www.behance.net/justfernandomalpica">
      <Behance class="hero__icon" />
      <p>Behance</p>
    </CardClickable>

    <CardClickable href="https://www.fiverr.com/jfmalpica">
      <Fiverr class="hero__icon" />
      <p>Fiverr</p>
    </CardClickable>
  </nav>
</section>

<script>
  const button = document.querySelector("#card-email-sender");

  if (button) {
    button.addEventListener("click", (e) => {
      window.location.href = "mailto:fernando_santosmalpica@outlook.com";
    });
  }
</script>

<style lang="scss">
  @use "@scss/variables.scss" as v;
  @use "@scss/mixins.scss" as m;

  .hero {
    display: grid;
    grid-template-columns: 4fr 6fr 4fr;
    grid-template-rows: fit-content auto;
    gap: v.$inner-separation;

    grid-template-areas:
      "avatar info    links"
      "avatar contact links";

    @include m.desktop-small {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(2, fit-content) auto;
      grid-template-areas:
        "avatar info links"
        "contact contact links";
    }

    @include m.tablet {
      grid-template-columns: repeat(2, 1fr);
      grid-template-areas:
        "avatar info"
        "contact contact"
        "links links";
    }

    @include m.mobile {
      display: flex;
      flex-direction: column;
    }

    &__icon {
      color: v.$lighten;
    }

    &__avatar {
      grid-area: avatar;

      aspect-ratio: 7 / 8;
      max-width: 300px;
      margin: auto auto;

      object-fit: cover;

      border-radius: v.$border-radius;

      @include m.tablet {
        aspect-ratio: 1 / 1;
      }
    }

    &__info {
      grid-area: info;
      gap: 15px;
      h1 {
        font-size: clamp(1.5rem, 2vw + 1rem, 2.5rem);
      }
    }

    &__contact {
      grid-area: contact;
      @include m.container($gap: v.$inner-separation);

      .contact-card {
        display: flex;
        flex-direction: row;
        justify-content: space-evenly;
        align-items: center;
        gap: 10px;
      }

      #card-email-sender {
        @include m.card-hover;
        cursor: pointer;
      }
    }

    &__links {
      grid-area: links;
      @include m.container($gap: v.$inner-separation);

      .hero__icon {
        margin-bottom: 5px;
      }
    }
  }
</style>

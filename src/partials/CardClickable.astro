---
import Card from "./Card.astro";
const {
  class: className,
  href: extLink,
  target: tar = "_blank",
  ...rest
} = Astro.props;
---

<a
  class="clickable-card-anchor"
  href={extLink}
  target={tar}
  rel="noopener noreferrer"
>
  <Card
    class={className ? `${className} clickable-card` : "clickable-card"}
    {...rest}
  >
    <slot />
  </Card>
</a>

<style lang="scss">
  @use "@scss/variables.scss" as v;
  @use "@scss/mixins.scss" as m;

  .clickable-card {
    height: 100%;
    @include m.card-hover;

    &-anchor {
      color: v.$light;
      text-decoration: none;
    }
  }
</style>
